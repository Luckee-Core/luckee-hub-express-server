[
  {
    "id": "lead-studio",
    "name": "Lead Studio",
    "description": "Lead CRM, research workers, email queue",
    "repos": [
      {
        "repoType": "express",
        "repoName": "lead-studio-express-server",
        "defaultApiPort": 3032,
        "healthPath": "/api/health"
      },
      {
        "repoType": "nextjs",
        "repoName": "lead-studio-web-open-source",
        "defaultWebPortStart": 3033
      }
    ]
  },
  {
    "id": "my-health",
    "name": "My Health",
    "description": "Self-hosted health dashboard",
    "repos": [
      {
        "repoType": "express",
        "repoName": "my-health-open-source-express-server",
        "defaultApiPort": 3009,
        "healthPath": "/api/health"
      },
      {
        "repoType": "nextjs",
        "repoName": "my-health-open-source",
        "defaultWebPortStart": 3010
      }
    ],
    "localDatabase": {
      "kind": "postgres",
      "databaseName": "my_health",
      "migrationsDir": "migrations",
      "migrationFiles": [
        "001_hospitals_specialties_doctors_appointments.sql",
        "002_focus_areas_daily_entries.sql"
      ],
      "expectedTables": [
        "hospitals",
        "specialties",
        "doctors",
        "appointments",
        "focus_areas",
        "daily_entries"
      ],
      "postgres": {
        "host": "127.0.0.1",
        "port": 5432,
        "formula": "postgresql@16",
        "installCommand": "brew install postgresql@16",
        "startCommand": "brew services start postgresql@16",
        "stopCommand": "brew services stop postgresql@16"
      }
    }
  },
