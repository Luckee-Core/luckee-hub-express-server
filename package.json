{
  "name": "luckee-hub-express-server",
  "version": "1.0.0",
  "description": "Luckee Dev Hub local API — studio status probes and macOS launcher",
  "main": "index.ts",
  "scripts": {
    "start": "ts-node index.ts",
    "dev": "nodemon --exec ts-node index.ts",
    "build": "tsc",
    "build:watch": "tsc --watch",
    "postinstall": "sh scripts/postinstall.sh"
  },
  "dependencies": {
    "express": "^5.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "node-pty": "^1.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^25.9.1",
    "@types/ws": "^8.5.14",
    "typescript": "^6.0.3",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.11"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
